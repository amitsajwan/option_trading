# Core infra
REDIS_PORT=6379
REDIS_DB=0
MONGO_PORT=27017
MONGO_DB=trading_ai
MONGO_COLL_SNAPSHOTS=phase1_market_snapshots
MONGO_COLL_STRATEGY_VOTES=strategy_votes
MONGO_COLL_TRADE_SIGNALS=trade_signals
MONGO_COLL_STRATEGY_POSITIONS=strategy_positions
MONGO_COLL_SNAPSHOTS_HISTORICAL=phase1_market_snapshots_historical
MONGO_COLL_STRATEGY_VOTES_HISTORICAL=strategy_votes_historical
MONGO_COLL_TRADE_SIGNALS_HISTORICAL=trade_signals_historical
MONGO_COLL_STRATEGY_POSITIONS_HISTORICAL=strategy_positions_historical

# Instrument + strategy
INSTRUMENT_SYMBOL=BANKNIFTY26MARFUT
# --- TradingBrain (deterministic / playbook profiles) ---
# BRAIN_ENABLED=true
# BRAIN_CONSENSUS_MIN_AGREEING=1
# BRAIN_CONSENSUS_REQUIRE_DIRECTION=false
# Path to nightly build_daily_regime_features.json (runtime VM)
# BRAIN_DAILY_FEATURES_PATH=/app/.data/ml_pipeline/daily_regime_features.json
# BRAIN_LLM_ENABLED=false
# BRAIN_LLM_API_KEY=
# BRAIN_LLM_MODEL=gpt-4o

# --- R1S top-3 paper / historical replay (recommended research lane) ---
# STRATEGY_ENGINE=deterministic
# STRATEGY_PROFILE_ID=r1s_top3_paper_v1
# STRATEGY_MIN_CONFIDENCE=0.50
# STRATEGY_ROLLOUT_STAGE_HISTORICAL=paper
# RISK_VIX_HALT_THRESHOLD=18
# RISK_VIX_RESUME_THRESHOLD=16
# --- ml_pure live (needs bundles + guard file) ---
STRATEGY_ENGINE=ml_pure
STRATEGY_PROFILE_ID=
# Premium stop: fraction (0.10) or percent (10) — close when option premium PnL <= -stop
# STRATEGY_PREMIUM_STOP_LOSS_PCT=0.10
STRATEGY_MIN_CONFIDENCE=0.65
STRATEGY_REDIS_PUBLISH_ENABLED=1
STRATEGY_ENHANCED_VELOCITY=0
# Required for ml_pure live startup: set either RUN_ID + MODEL_GROUP or MODEL_PACKAGE + THRESHOLD_REPORT.
ML_PURE_RUN_ID=
ML_PURE_MODEL_GROUP=
ML_PURE_MODEL_PACKAGE=
ML_PURE_THRESHOLD_REPORT=
ML_PURE_MAX_FEATURE_AGE_SEC=90
# Historical replay should not compare snapshot timestamps to wall clock.
ML_PURE_MAX_FEATURE_AGE_SEC_HISTORICAL=0
ML_PURE_CE_THRESHOLD=
ML_PURE_PE_THRESHOLD=
# These defaults are intentionally non-live. For supported ml_pure runtime, change
# to capped_live + 0.25 and provide STRATEGY_ML_RUNTIME_GUARD_FILE.
STRATEGY_ROLLOUT_STAGE=paper
STRATEGY_POSITION_SIZE_MULTIPLIER=1.0
STRATEGY_ML_RUNTIME_GUARD_FILE=
# Historical replay should use a dedicated test guard, not the live runtime guard.
STRATEGY_ML_RUNTIME_GUARD_FILE_HISTORICAL=.run/ml_runtime_guard_historical_test.json
RISK_PROFILE=
RISK_LOT_SIZING_MODE=risk_based
RISK_NOTIONAL_PER_TRADE=0
RISK_LOT_BUDGET_USES_LOT_SIZE=1
RISK_MAX_DAILY_LOSS_PCT=0.02
RISK_MAX_CONSECUTIVE_LOSSES=3
RISK_MAX_LOTS_PER_TRADE=5
RISK_PER_TRADE_PCT=0.005
RISK_CAPITAL_ALLOCATED=500000
RISK_VIX_HALT_THRESHOLD=15
RISK_VIX_RESUME_THRESHOLD=8
STRATEGY_STARTUP_WARMUP_MINUTES=0
STRATEGY_STARTUP_WARMUP_EVENTS=0
STRATEGY_STRIKE_SELECTION_POLICY=atm
STRATEGY_STRIKE_MAX_OTM_STEPS=2
STRATEGY_STRIKE_MIN_OI=50000
STRATEGY_STRIKE_MIN_VOLUME=15000
STRATEGY_STRIKE_LIQUIDITY_WEIGHT=1.0
STRATEGY_STRIKE_AFFORDABILITY_WEIGHT=0.25
STRATEGY_STRIKE_DISTANCE_PENALTY=0.05

# Smart strike selection: tiered ATM / 1-OTM / 2-OTM based on confidence + IV + regime.
# Master switch — set to 1 to enable tiered selection (ml_pure engine only needs this).
STRATEGY_SMART_STRIKE_ENABLED=1
# Hard premium cap — skip trade if no strike is affordable (0 = no cap)
SMART_STRIKE_MAX_PREMIUM=600
SMART_STRIKE_IV_REJECT_PCTILE=90.0
# Tier 1 — 1-OTM: conf >= 0.55 (entry gate for any OTM)
SMART_STRIKE_OTM_CONFIDENCE=0.55
SMART_STRIKE_OTM_IV_CEIL=60.0
# Tier 2 — 2-OTM: conf >= 0.65, any regime, min OI=100k
SMART_STRIKE_OTM2_ENABLED=1
SMART_STRIKE_OTM2_CONFIDENCE=0.65
SMART_STRIKE_OTM2_IV_CEIL=50.0
SMART_STRIKE_OTM2_REGIMES=
SMART_STRIKE_OTM2_MAX_BAR_HOUR=0
SMART_STRIKE_OTM2_MIN_OI=100000
# Tier 3 — 3-OTM: conf >= 0.75, BREAKOUT/TRENDING, before 12:00, min OI=75k
SMART_STRIKE_OTM3_ENABLED=1
SMART_STRIKE_OTM3_CONFIDENCE=0.75
SMART_STRIKE_OTM3_IV_CEIL=40.0
SMART_STRIKE_OTM3_REGIMES=BREAKOUT,TRENDING
SMART_STRIKE_OTM3_MAX_BAR_HOUR=12
SMART_STRIKE_OTM3_MIN_OI=75000
# Tier 4 — 4-OTM (~200-350 premium): conf >= 0.85, BREAKOUT only, before 11:00, min OI=50k
SMART_STRIKE_OTM4_ENABLED=1
SMART_STRIKE_OTM4_CONFIDENCE=0.85
SMART_STRIKE_OTM4_IV_CEIL=30.0
SMART_STRIKE_OTM4_REGIMES=BREAKOUT
SMART_STRIKE_OTM4_MAX_BAR_HOUR=11
SMART_STRIKE_OTM4_MIN_OI=50000

# Session gate (IST / NSE)
MARKET_SESSION_ENABLED=1
MARKET_TIMEZONE=Asia/Kolkata
MARKET_OPEN_TIME=09:15
MARKET_CLOSE_TIME=15:30
NSE_HOLIDAYS_FILE=/app/config/nse_holidays.json
IDLE_SLEEP_SECONDS=60

# Historical replay consumer lock (Redis). Instance id is stable across force-recreate;
# only disable on a dedicated eval host with a single historical consumer.
# STRATEGY_CONSUMER_LOCK_INSTANCE_ID=strategy_app_historical
# STRATEGY_SINGLE_CONSUMER_LOCK_ENABLED=1
# STRATEGY_SINGLE_CONSUMER_LOCK_TTL_SEC=60
# STRATEGY_SINGLE_CONSUMER_LOCK_MAX_WAIT_SEC=90

# Topics
LIVE_TOPIC=market:snapshot:v1
HISTORICAL_TOPIC=market:snapshot:v1:historical
STRATEGY_VOTE_TOPIC=market:strategy:votes:v1
TRADE_SIGNAL_TOPIC=market:strategy:signals:v1
STRATEGY_POSITION_TOPIC=market:strategy:positions:v1
STRATEGY_VOTE_TOPIC_HISTORICAL=market:strategy:votes:v1:historical
TRADE_SIGNAL_TOPIC_HISTORICAL=market:strategy:signals:v1:historical
STRATEGY_POSITION_TOPIC_HISTORICAL=market:strategy:positions:v1:historical

# Secrets
KITE_CREDENTIALS_PATH=/app/secrets/credentials.json

# Optional runtime ports
INGESTION_API_PORT=8004
DASHBOARD_PORT=8008
STRATEGY_EVAL_UI_PORT=8011
DASHBOARD_CORS_ORIGINS=http://localhost:8011,http://127.0.0.1:8011,http://localhost:5173,http://127.0.0.1:5173
INGESTION_COLLECTORS_ENABLED=0

# Snapshot tuning
ML_PIPELINE_DISABLE_KITE_BACKFILL=1
# Containers mount repo parquet under /app/.data/ml_pipeline/parquet_data.
# Historical replay requires the canonical snapshots dataset under that path.
SNAPSHOT_PARQUET_BASE=/app/.data/ml_pipeline/parquet_data
MONGO_COLL_STRATEGY_EVAL_RUNS=strategy_eval_runs
STRATEGY_EVAL_COMMAND_TOPIC=strategy:eval:command
STRATEGY_EVAL_GLOBAL_CHANNEL=strategy:eval:global
STRATEGY_EVAL_RUN_CHANNEL_PREFIX=strategy:eval:run:

# ═══════════════════════════════════════════════════════════════════════════
# LIVE TRADING CONFIGURATION
# Sprint 1–2 features. Read LIVE_TRADING_IMPLEMENTATION.md before changing.
# ═══════════════════════════════════════════════════════════════════════════

# ─── E1: Execution Bridge ──────────────────────────────────────────────────
#
# Controls whether real Kite orders are placed or simulated (paper).
# Change one variable to switch between modes — no code changes needed.
#
# Rollout stages:
#   paper   → No real orders. Current default. Safe for strategy research.
#   kite    → Real NFO orders via Zerodha Kite Connect.
#   shadow  → Both paper + real (1 lot) simultaneously. Coming Sprint 3.
#
# EXECUTION_ADAPTER=paper
#
# Required for kite / shadow mode:
# KITE_API_KEY=your_api_key_here
# KITE_ACCESS_TOKEN=your_token_here   (refresh daily — see E5-S2)
#
# Order fill polling:
# ORDER_FILL_TIMEOUT_SEC=30    # give up waiting for fill after 30s
# ORDER_POLL_INTERVAL_SEC=1    # check order status every 1s
#
# Fill tracking (records real P&L to MongoDB):
# FILL_TRACKER_ENABLED=1
# EXECUTION_FILLS_STREAM=execution:fills:v1
# MONGO_COLL_EXECUTION_FILLS=execution_fills
#
# Health endpoint port for execution_app:
# EXECUTION_APP_HEALTH_PORT=8009

# ─── E2: Exit Policy Stack ─────────────────────────────────────────────────
#
# Addresses the primary P&L gap: 17.5% MFE capture (2026-06-01 baseline).
# Default stack: PremiumTarget → TrailingStop → ThesisFail
#
# HOW TO ACTIVATE:
#   Set EXIT_POLICY_STACK_ENABLED=1 in your .env file.
#   All other settings have safe defaults. Tune after observing first session.
#
# Entry window (IST, HH:MM). Leave blank to use session_phase=="ACTIVE" (09:45–14:30).
# WARNING: extending beyond 09:35 or 15:05 puts the ML model OOS.
ENTRY_WINDOW_START_IST=
ENTRY_WINDOW_END_IST=

# Master switch (0 = off, preserves existing behaviour; 1 = active)
EXIT_POLICY_STACK_ENABLED=0

# Profit target — exit when premium P&L reaches this %
# 1.5% captures a good chunk of the typical 1.7% avg MFE
EXIT_PREMIUM_TARGET_PCT=0.015

# Trailing stop — activates once MFE exceeds activation threshold
# Then trails trail_pct below the peak — never moves backwards
# Example: MFE=2.0%, trail=0.5% → locked in at 1.5% minimum
EXIT_TRAILING_ACTIVATION_PCT=0.01
EXIT_TRAILING_TRAIL_PCT=0.005

# Thesis fail — exit early if trade shows no positive movement after N bars
# Catches wrong-direction entries before they drain (CE trades 3/4/5 on 2026-06-01)
EXIT_THESIS_FAIL_BARS=3
EXIT_THESIS_FAIL_MIN_MFE=0.002

# ─── E3: Entry Gate Hardening ─────────────────────────────────────────────
#
# Consensus bypass path was firing at confidence >= 0.50 but the entry gate
# requires 0.65. These settings align them so sub-threshold entries are blocked.
#
# Align bypass threshold to entry gate (0.65 = same as STRATEGY_MIN_CONFIDENCE)
CONSENSUS_BYPASS_MIN_CONFIDENCE=0.65

# SIDEWAYS regime: require higher direction margin (noisy signals in flat markets)
# Global margin is DIRECTION_CONSENSUS_MIN_MARGIN=1.25
# SIDEWAYS overrides to 2.0 — trade only when direction is clearly one-sided
DIRECTION_MIN_MARGIN_SIDEWAYS=2.0

# ─── E4: Risk Sizing ──────────────────────────────────────────────────────
#
# Position sizing tied to capital at risk per trade.
# Formula: lots = floor(capital × risk_pct / (entry_premium × lot_size × stop_pct))
#
# RISK_CALCULATOR=fixed_fraction   (matches existing risk_based mode)
# RISK_FRACTION_PCT=0.01           (1% of RISK_CAPITAL_ALLOCATED at risk per trade)
#
# With defaults: capital=500_000, risk=1%, entry=1000, stop=40%
#   max_loss_per_lot = 1000 × 15 × 0.40 = 6000
#   risk_capital = 5000
#   lots = floor(5000/6000) = 0 → clamps to 1
# Raise RISK_CAPITAL_ALLOCATED or lower RISK_FRACTION_PCT to get more lots.
#
# RISK_CALCULATOR=fixed_fraction
# RISK_FRACTION_PCT=0.01

# ─── E1-S5: Shadow Mode ───────────────────────────────────────────────────
#
# Shadow mode runs real orders (1 lot) + paper side-by-side.
# Use for 5 days before cutting over to full live.
#
# To switch to shadow:
#   EXECUTION_ADAPTER=shadow
#
# SHADOW_MAX_LOTS=1                   caps real Kite orders during shadow
# SHADOW_REAL_FILLS_STREAM=execution:fills:real:v1
# SHADOW_PAPER_FILLS_STREAM=execution:fills:paper:v1

# ─── E5: Alerts ───────────────────────────────────────────────────────────
#
# Telegram notifications on trade open, close, halt, and rejected orders.
#
# HOW TO CONFIGURE:
#   1. Create a bot via @BotFather → copy the token
#   2. Add the bot to your channel/group → get the chat_id
#   3. Set ALERT_ENABLED=1 to activate
#
ALERT_ENABLED=0
# ALERT_TELEGRAM_TOKEN=your_bot_token_here
# ALERT_TELEGRAM_CHAT_ID=your_chat_id_here
# ALERT_TELEGRAM_TIMEOUT=5

# ─── E5-S2: Kite Token Auto-Refresh ──────────────────────────────────────
#
# Exchanges a one-time request token for an access token at 08:30 IST.
# Run as cron job: python -m ingestion_app.token_refresh
#
# Required env (set on the VM, not in docker-compose):
# KITE_API_SECRET=your_api_secret
# KITE_REQUEST_TOKEN=one_time_token   (from login URL, set fresh each day)
# TOKEN_ENV_FILE_PATH=/opt/option_trading/.env  (optional: also update env file)

# ─── E5-S3: Daily P&L Report ─────────────────────────────────────────────
#
# End-of-day markdown report saved to docs/reports/YYYY-MM-DD.md
# Also sent via Telegram (uses same ALERT_TELEGRAM_* vars above).
# Run as cron: python -m market_data_dashboard.daily_report
# Cron time: 40 10 * * 1-5  (15:40 IST = 10:10 UTC)
#
# REPORT_OUTPUT_DIR=docs/reports
