# SHADOW profile — checklist council + selection gate, PAPER. Switchable overlay.
# Live:  PROFILE=shadow docker compose --env-file .env.compose --env-file ops/profiles/shadow.env up -d strategy_app
# SIM :  pass these as sim overrides (ops/run_sim_profile.sh shadow <date>)
ML_ENTRY_DIRECTION_MODE=checklist
OPPORTUNITY_GATE_ENABLED=1
ENTRY_VOL_GATE_ENABLED=0
ENTRY_ML_MIN_PROB=0.0
STRATEGY_MIN_CONFIDENCE=0.0
DIR_COUNCIL_MIN_AGREE=2
DIR_COUNCIL_USE_MODEL=0
