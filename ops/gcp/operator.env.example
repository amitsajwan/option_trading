# Copy to ops/gcp/operator.env and edit the values for your project.
# This file is sourced by Bash.
# Use shell-safe values and quotes.
# Do not leave placeholders like <org> or <project>.

# GCP project and locations
PROJECT_ID="my-gcp-project"
REGION="asia-south1"
ZONE="asia-south1-a"

# Repo checkout used by VM startup scripts
REPO_CLONE_URL="https://github.com/your-github-org/option_trading.git"
REPO_REF="main"

# Runtime and training sizing
RUNTIME_NAME="option-trading-runtime"
RUNTIME_MACHINE_TYPE="e2-standard-4"
TRAINING_MACHINE_TYPE="n2-standard-8"

# Runtime container source (GHCR, published by GitHub Actions)
# Compose expects images like:
#   ${GHCR_IMAGE_PREFIX}/strategy_app:${TAG}
# Example:
#   GHCR_IMAGE_PREFIX="ghcr.io/amitsajwan"
#   TAG="latest" (or a pinned git SHA tag like abc12345)
GHCR_IMAGE_PREFIX="ghcr.io/amitsajwan"
TAG="latest"

# Kept for infra bootstrap compatibility (Terraform creates Artifact Registry even if unused for runtime pulls)
REPOSITORY="option-trading-runtime"

# Cloud Storage buckets
MODEL_BUCKET_NAME="my-option-trading-models"
RUNTIME_CONFIG_BUCKET_NAME="my-option-trading-runtime-config"
SNAPSHOT_DATA_BUCKET_NAME=""
# Must sync into local .data/ml_pipeline on the VM startup scripts.
# Point this at the parent prefix that already contains parquet_data/,
# for example gs://my-training-data-root/ml_pipeline.
# After VM startup, the expected local path is:
#   /opt/option_trading/.data/ml_pipeline/parquet_data
# There is no repo-wide default shared data bucket.
DATA_SYNC_SOURCE="gs://my-training-data-root/ml_pipeline"

# Derived GCS prefixes
# Optional in operator.env. from_scratch_bootstrap.sh can derive these from
# MODEL_BUCKET_NAME and RUNTIME_CONFIG_BUCKET_NAME.
MODEL_BUCKET_URL="gs://my-option-trading-models/published_models"
RUNTIME_CONFIG_BUCKET_URL="gs://my-option-trading-runtime-config/runtime"
RAW_ARCHIVE_BUCKET_URL="gs://my-snapshot-data/banknifty_data"
SNAPSHOT_PARQUET_BUCKET_URL="gs://my-snapshot-data/parquet_data"

# Runtime profile
ENABLE_DASHBOARD_PROFILE=true
DASHBOARD_PORT=8008

# Optional GHCR auth for private packages (not needed for public images).
# GHCR_USERNAME="<github-username>"
# GHCR_TOKEN="<github-personal-access-token-with-read:packages>"

# Network access
SSH_SOURCE_RANGES="0.0.0.0/0"
DASHBOARD_SOURCE_RANGES="0.0.0.0/0"

# Training release defaults
MODEL_GROUP="banknifty_futures/h15_tp_auto"
PROFILE_ID="openfe_v9_dual"
STAGED_CONFIG="ml_pipeline_2/configs/research/staged_dual_recipe.default.json"

# Training VM creation helper
TRAINING_VM_NAME="option-trading-training-01"

# Optional local repo override for wrapper scripts
# REPO_ROOT="/path/to/option_trading"

# Optional local raw archive input.
# When set, run_snapshot_parquet_pipeline.sh uploads this local tree to RAW_ARCHIVE_BUCKET_URL
# before syncing it back to the VM cache and building parquet.
# Expected entries: banknifty_fut, banknifty_options, banknifty_spot, VIX or vix
# LOCAL_RAW_ARCHIVE_ROOT="/mnt/disks/raw/banknifty_data"

# Optional snapshot operator tuning.
# Defaults are conservative for reproducible GCP runs.
# Raise them only after the wrapper succeeds cleanly on your VM.
# NORMALIZE_JOBS="1"
# SNAPSHOT_JOBS="2"
# SNAPSHOT_SLICE_MONTHS="6"
# SNAPSHOT_SLICE_WARMUP_DAYS="90"
# CLEAN_PUBLISH_PREFIXES="1"
# VERIFY_PUBLISHED_PREFIXES="1"

# Stage 2 schema guard used by both the snapshot and training wrappers.
# The wrappers fail before publish/train if these columns are absent from stage2_direction_view.
# STAGE2_REQUIRED_COLUMNS="pcr_change_5m,pcr_change_15m,atm_oi_ratio,near_atm_oi_ratio,atm_ce_oi,atm_pe_oi"

# Training wrapper helper.
# When enabled, run_staged_release_pipeline.sh will install missing libgomp1 for LightGBM on Ubuntu.
# AUTO_INSTALL_SYSTEM_PACKAGES="1"
