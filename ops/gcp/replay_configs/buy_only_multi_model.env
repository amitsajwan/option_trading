# Buy-only options preset (no short premium strategies).
#
# Use this when you want strict BUY CE/BUY PE behavior in replay.
# Profile debit_multi_v1 contains long-option playbooks only.

STRATEGY_ENGINE=deterministic
STRATEGY_PROFILE_ID=debit_multi_v1

# Optional model overlays (uncomment to enable).
# Entry ML (timing gate)
# ENTRY_ML_MODEL_PATH=/app/ml_pipeline_2/artifacts/entry_only/published/entry_only_model.joblib
# ENTRY_ML_MIN_PROB=0.65

# Direction ML (side tie-break / overlay)
# DIRECTION_ML_MODEL_PATH=/app/ml_pipeline_2/artifacts/direction_only/published/direction_only_model.joblib
# DIRECTION_ML_WEIGHT=0.40
# DIRECTION_ML_FILTER_MIN_PROB=0.52

# Keep both buy directions allowed (CE + PE).
ML_ENTRY_BLOCK_CE=0
ML_ENTRY_BLOCK_PE=0

# Extra market context
DEPTH_FEED_ENABLED=1
