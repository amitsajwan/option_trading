# Example: point the engine at a custom-trained ML bundle.
#
# Train a new bundle on captured live data (now including depth + nifty_context
# + block_flow + underlying_context fields) via ml_pipeline_2, then reference
# the output paths here. The engine will load these at strategy_app_historical
# startup and use them for the replay.
#
# Three classes of model knobs you can override:

# ── Pure-ML (staged) engine path ──────────────────────────────────────────────
# Replace ML_PURE_* to point at a fresh staged bundle. Set STRATEGY_ENGINE=ml_pure
# and pick a profile that uses it (e.g. trader_master_ml_entry_v1).
STRATEGY_ENGINE=ml_pure
STRATEGY_PROFILE_ID=trader_master_ml_entry_v1
ML_PURE_RUN_ID=YOUR_NEW_RUN_ID_HERE
ML_PURE_MODEL_GROUP=banknifty_futures
ML_PURE_MODEL_PACKAGE=h15_tp_auto

# ── Deterministic engine + direction-ML overlay ───────────────────────────────
# Path to a direction-only model trained on the new feature set (with
# depth_ce_bid_dom etc. as candidate features):
# DIRECTION_ML_MODEL_PATH=/app/ml_pipeline_2/artifacts/direction_only/YOUR_NEW_BUNDLE/direction_only_model.joblib
# DIRECTION_ML_WEIGHT=0.40
# DIRECTION_ML_FILTER_MIN_PROB=0.52

# ── Entry-ML overlay (det-engine, ML as primary voter) ────────────────────────
# ENTRY_ML_MODEL_PATH=/app/ml_pipeline_2/artifacts/entry_ml/YOUR_NEW_BUNDLE/entry_model.joblib
# ENTRY_ML_MIN_PROB=0.55

# ── Option-PnL bundle (the multi-bundle stack) ────────────────────────────────
# Comma-separated paths; engine loads all and uses the highest-confidence side.
# OPTION_PNL_MODEL_BUNDLE=/app/ml_pipeline_2/artifacts/option_pnl_bundles/YOUR_PE_BUNDLE,/app/ml_pipeline_2/artifacts/option_pnl_bundles/YOUR_CE_BUNDLE

# Anything you DON'T list here inherits from .env.compose. Keep presets small —
# one experiment per preset, with a comment at the top describing the hypothesis.
