# LLM provider split for the trading brain.
#   Morning session (day posture)      -> GEMINI  (can web-ground; runs 1x/day)
#   Entry / direction advisor (per-bar)-> GROQ    (fast, high RPM, ~1 call/trade)
#
# Copy the values you need into the runtime .env.compose (or `source` this file).
# Keys here are PLACEHOLDERS — never commit real keys; rotate any that leak.

# ─────────────────────────────────────────────────────────────────────────────
# 1) MORNING SESSION  →  GEMINI   (LLMContextProvider / strategy_app/brain/providers/llm_stub.py)
#    Once per day at morning briefing, OFF the hot path. Advisory only.
# ─────────────────────────────────────────────────────────────────────────────
BRAIN_LLM_ENABLED=true
BRAIN_LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
BRAIN_LLM_MODEL=gemini-2.5-flash          # thinking model OK here: 1 call/day, give it room
BRAIN_LLM_MAX_TOKENS=1200                 # thinking models need headroom or JSON truncates
BRAIN_LLM_API_KEY=REPLACE_WITH_GEMINI_KEY
BRAIN_LLM_TIMEOUT_S=25
BRAIN_LLM_TEMPERATURE=0.2
BRAIN_LLM_JSON_MODE=true

# Optional: native Gemini web-grounding sense (real news, not "unknown")
#   strategy_app/brain/oversight/gemini_web.py  — uses the native generateContent + google_search
GEMINI_WEB_API_KEY=REPLACE_WITH_GEMINI_KEY
GEMINI_WEB_MODEL=gemini-2.5-flash

# ─────────────────────────────────────────────────────────────────────────────
# 2) ENTRY / DIRECTION ADVISOR  →  GROQ
#    Per-entry direction call (~1/trade live). Non-thinking, fast, clean JSON.
#    Used by strategy_app/tools/llm_direction_replay.py (offline) and the live
#    direction advisor once shadow-validated.
# ─────────────────────────────────────────────────────────────────────────────
GROQ_API_KEY=REPLACE_WITH_GROQ_KEY
DIRECTION_LLM_PROVIDER=groq
DIRECTION_LLM_MODEL=llama-3.3-70b-versatile
DIRECTION_LLM_TIMEOUT_S=12

# ─────────────────────────────────────────────────────────────────────────────
# 3) LIVE SHADOW (paper) — log what the LLM WOULD pick; never changes the order.
#    Off the hot path (daemon thread). Watch it at:
#       GET /api/strategy/brain/direction-shadow
#    Reconcile accuracy offline with tools/reconcile_direction_shadow.py.
# ─────────────────────────────────────────────────────────────────────────────
DIRECTION_SHADOW_ENABLED=1

# Gemini web-grounding cache (news/RBI/macro) fed to Groq as soft context.
# Off by default; the only NEW information the structural senses lack.
GROUNDING_ENABLED=1
GROUNDING_TTL_SECONDS=1800                 # refresh at most every 30 min (free-tier 429s)
