{
  "schema_version": 1,
  "experiment_kind": "staged_dual_recipe_v1",
  "_comment": "Direction-only research: CE vs PE without entry_label gate. Deep Optuna HPO on stage2 (velocity + midday feature sets). Reuses stage1 from deep_hpo_c1 to skip S1 search. Update stage1_reuse.source_run_dir if that run is missing on the VM.",
  "inputs": {
    "parquet_root": "../../../.data/ml_pipeline/parquet_data",
    "support_dataset": "snapshots_ml_flat_v2"
  },
  "outputs": {
    "artifacts_root": "../../artifacts/research",
    "run_name": "direction_only_hpo_v1"
  },
  "catalog": {
    "models_by_stage": {
      "stage1": ["xgb_balanced"],
      "stage2": [
        "xgb_shallow",
        "xgb_balanced",
        "xgb_regularized",
        "xgb_deep_v1",
        "xgb_deep_slow_v1",
        "lgbm_fast",
        "lgbm_dart",
        "lgbm_large_v1",
        "lgbm_large_dart_v1",
        "logreg_balanced",
        "logreg_c01"
      ],
      "stage3": ["xgb_balanced", "lgbm_dart"]
    },
    "feature_sets_by_stage": {
      "stage1": ["fo_velocity_v1"],
      "stage2": [
        "fo_velocity_v1",
        "fo_midday_direction_regime_v1",
        "fo_midday_time_aware_plus_oi_iv",
        "fo_midday_asymmetry",
        "fo_oi_pcr_momentum"
      ],
      "stage3": ["fo_velocity_v1"]
    },
    "recipe_catalog_id": "midday_l3_adjacent_v1"
  },
  "windows": {
    "research_train": { "start": "2020-08-03", "end": "2024-04-30" },
    "research_valid": { "start": "2024-05-01", "end": "2024-07-31" },
    "full_model": { "start": "2020-08-03", "end": "2024-07-31" },
    "final_holdout": { "start": "2024-08-01", "end": "2024-10-31" }
  },
  "views": {
    "stage1_view_id": "stage1_entry_view_v2",
    "stage2_view_id": "stage2_direction_view_v2",
    "stage3_view_id": "stage3_recipe_view_v2"
  },
  "labels": {
    "stage1_labeler_id": "entry_best_recipe_v1",
    "stage2_labeler_id": "direction_market_up_all_v1",
    "stage3_labeler_id": "recipe_best_positive_v1"
  },
  "training": {
    "stage1_trainer_id": "binary_catalog_v1",
    "stage2_trainer_id": "binary_catalog_v1",
    "stage3_trainer_id": "ovr_recipe_catalog_v1",
    "preprocess": {
      "max_missing_rate": 0.35,
      "clip_lower_q": 0.01,
      "clip_upper_q": 0.99
    },
    "cv_config": {
      "train_days": 84,
      "valid_days": 21,
      "test_days": 21,
      "step_days": 21,
      "purge_days": 0,
      "embargo_days": 0,
      "purge_mode": "days",
      "embargo_rows": 0,
      "event_end_col": null
    },
    "objectives_by_stage": {
      "stage1": "brier",
      "stage2": "brier",
      "stage3": "brier"
    },
    "random_state": 42,
    "runtime": { "model_n_jobs": 8 },
    "cost_per_trade": 0.0006,
    "stage2_session_filter": { "enabled": false },
    "stage2_target_redesign": { "enabled": false },
    "stage2_decisive_move_filter": { "min_ce_pe_edge": 0.002 },
    "search_options_by_stage": {
      "stage1": {
        "hpo": {
          "enabled": true,
          "strategy": "optuna",
          "trials_per_model": 12,
          "sampler_seed": 42
        },
        "max_experiments": 8,
        "max_elapsed_seconds": 1800
      },
      "stage2": {
        "hpo": {
          "enabled": true,
          "strategy": "optuna",
          "trials_per_model": 40,
          "sampler_seed": 42
        },
        "max_experiments": 120,
        "max_elapsed_seconds": 14400
      },
      "stage3": {
        "hpo": {
          "enabled": true,
          "strategy": "optuna",
          "trials_per_model": 15,
          "sampler_seed": 42
        },
        "max_experiments": 20,
        "max_elapsed_seconds": 3600
      }
    }
  },
  "policy": {
    "stage1_policy_id": "entry_threshold_v1",
    "stage2_policy_id": "direction_dual_threshold_v1",
    "stage3_policy_id": "recipe_fixed_baseline_guard_v1",
    "stage1": { "threshold_grid": [0.5, 0.55, 0.6] },
    "stage2": {
      "ce_threshold_grid": [0.52, 0.55, 0.58, 0.6, 0.62],
      "pe_threshold_grid": [0.52, 0.55, 0.58, 0.6, 0.62],
      "min_edge_grid": [0.02, 0.05, 0.08, 0.1]
    },
    "stage3": {
      "threshold_grid": [0.5, 0.55],
      "margin_grid": [0.02, 0.05]
    }
  },
  "runtime": {
    "block_expiry": false,
    "stage2_cv_gate_mode": "record_only",
    "prefilter_gate_ids": [
      "rollout_guard_v1",
      "risk_halt_pause_v1",
      "valid_entry_phase_v1",
      "startup_warmup_v1",
      "feature_freshness_v1",
      "feature_completeness_v1"
    ]
  },
  "publish": { "publisher_id": "staged_bundle_v1" },
  "hard_gates": {
    "stage1": {
      "roc_auc_min": 0.52,
      "brier_max": 0.25,
      "roc_auc_drift_half_split_max_abs": 0.08
    },
    "stage2": {
      "roc_auc_min": 0.52,
      "brier_max": 0.25
    },
    "stage3": {
      "max_drawdown_slack": 0.02
    },
    "combined": {
      "profit_factor_min": 1.0,
      "max_drawdown_pct_max": 0.15,
      "trades_min": 30,
      "net_return_sum_min": -0.05,
      "side_share_min": 0.25,
      "side_share_max": 0.75,
      "block_rate_min": 0.0
    }
  }
}
