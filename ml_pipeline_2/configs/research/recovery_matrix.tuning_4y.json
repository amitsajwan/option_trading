{
  "inputs": {
    "base_manifest": "fo_expiry_aware_recovery.tuning_4y.json"
  },
  "matrix": {
    "tp_grid": [0.002, 0.0025, 0.003],
    "sl_grid": [0.0008, 0.001, 0.0012],
    "horizon_grid": [15, 20],
    "barrier_modes": ["fixed", "atr_scaled"],
    "models": [
      "xgb_shallow",
      "xgb_balanced",
      "xgb_regularized",
      "xgb_deep_v1",
      "xgb_deep_slow_v1",
      "lgbm_fast",
      "lgbm_dart",
      "lgbm_large_v1",
      "lgbm_large_dart_v1"
    ],
    "feature_sets": ["fo_expiry_aware_v2", "fo_oi_pcr_momentum", "fo_no_time_context"]
  },
  "outputs": {
    "matrix_root": "../../artifacts/research_matrices",
    "matrix_name": "recovery_tuning_4y"
  },
  "launch": {
