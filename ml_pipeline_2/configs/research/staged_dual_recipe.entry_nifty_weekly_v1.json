    "research_valid": {
      "start": "2025-01-01",
      "end": "2025-09-30"
    },
    "full_model": {
      "start": "2021-06-01",
      "end": "2025-09-30"
    },
    "final_holdout": {
      "start": "2025-10-01",
      "end": "2026-06-25"
    }
  },
  "views": {
    "stage1_view_id": "stage1_entry_view_dhan",
    "stage2_view_id": "stage2_direction_view_dhan",
