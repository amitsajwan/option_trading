{
  "schema_version": 1,
  "experiment_kind": "staged_dual_recipe_v1",
  "_comment": "NIFTY weekly-regime entry model (2021-06..2026-06). snapshots_nifty_v1. Weekly expiry throughout — no structural break (unlike BankNifty Nov-2024 monthly switch). min_points=50 => ~0.21% at NIFTY 24000 (matches BankNifty 100pt/50000). VWAP/volume auto-dropped by max_missing_rate=0.35.",
