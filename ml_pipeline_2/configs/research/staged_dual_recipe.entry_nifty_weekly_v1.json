    "parquet_root": "../../../.data/ml_pipeline/parquet_data",
    "support_dataset": "snapshots_nifty_v1",
    "support_window": {
      "start": "2021-06-01",
      "end": "2026-06-25"
    }
  },
  "outputs": {
    "artifacts_root": "../../artifacts/research",
    "run_name": "entry_nifty_weekly_v1"
  },
  "catalog": {
    "models_by_stage": {
      "stage1": [
        "xgb_shallow",
        "xgb_balanced",
        "xgb_regularized",
        "lgbm_fast",
        "lgbm_dart",
        "logreg_balanced"
      ],
      "stage2": [
        "xgb_balanced"
      ],
      "stage3": [
        "xgb_balanced"
      ]
    },
    "feature_sets_by_stage": {
      "stage1": [
        "fo_velocity_v1",
        "fo_bmm_v1",
        "fo_midday_time_aware_plus_oi_iv",
        "fo_midday_asymmetry",
        "fo_oi_pcr_momentum"
      ],
      "stage2": [
        "fo_bmm_v1"
      ],
      "stage3": [
        "fo_bmm_v1"
      ]
    },
    "recipe_catalog_id": "fixed_l0_l3_v1"
  },
  "windows": {
