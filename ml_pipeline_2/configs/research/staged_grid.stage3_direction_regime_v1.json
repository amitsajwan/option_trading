{
  "schema_version": 1,
  "experiment_kind": "staged_training_grid_v1",
  "inputs": {
    "base_manifest_path": "staged_dual_recipe.stage3_policy_paths_v1.json"
  },
  "outputs": {
    "artifacts_root": "../../artifacts/research",
    "run_name": "staged_grid_stage3_direction_regime_v1"
  },
  "selection": {
    "ranking_strategy": "stage3_policy_paths_v1",
    "stage2_hpo_escalation": {
      "roc_auc_min": 0.55,
      "brier_max": 0.22
    },
    "robustness_probe": {
      "enabled": true,
      "top_k": 3,
      "iterations": 200,
      "random_seed": 42,
      "splits": [
        "research_valid",
        "final_holdout"
      ],
      "resample_unit": "trade_date"
    }
  },
  "grid": {
    "research_only": true,
    "max_parallel_runs": 2,
    "runs": [
      {
        "run_id": "s3_regime_baseline",
        "model_group_suffix": "_s3_regime_baseline",
        "reuse_stage1_from": "stage3_baseline_dynamic",
        "overrides": {
          "outputs": {
            "run_name": "staged_s3_regime_baseline"
          },
          "catalog": {
            "feature_sets_by_stage": {
              "stage2": ["fo_midday_direction_regime_v1"]
            }
          }
        }
      },
      {
        "run_id": "s3_regime_balanced",
        "model_group_suffix": "_s3_regime_balanced",
        "reuse_stage1_from": "stage3_baseline_dynamic",
        "overrides": {
          "outputs": {
            "run_name": "staged_s3_regime_balanced"
          },
          "catalog": {
            "feature_sets_by_stage": {
              "stage2": ["fo_midday_direction_regime_v1"]
            }
          },
          "policy": {
            "stage2_policy_id": "direction_gate_economic_balance_v1"
          }
        }
      }
    ]
  }
}
