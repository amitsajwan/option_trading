{
  "schema_version": 1,
  "experiment_kind": "staged_training_grid_v1",
  "inputs": {
    "base_manifest_path": "staged_dual_recipe.velocity_screen_fast_v1.json"
  },
  "outputs": {
    "artifacts_root": "../../artifacts/research",
    "run_name": "staged_grid_velocity_screen_fast_v1"
  },
  "selection": {
    "ranking_strategy": "stage3_policy_paths_v1",
    "stage2_hpo_escalation": {
      "roc_auc_min": 0.55,
      "brier_max": 0.22
    },
    "robustness_probe": {
      "enabled": true,
      "top_k": 3,
      "iterations": 200,
      "random_seed": 42,
      "splits": ["research_valid", "final_holdout"],
      "resample_unit": "trade_date"
    }
  },
  "grid": {
    "research_only": true,
    "max_parallel_runs": 2,
    "runs": [
      {
        "run_id": "all_day",
        "model_group_suffix": "_vel_all_day",
        "overrides": {
          "outputs": { "run_name": "vel_all_day" }
        }
      },
      {
        "run_id": "midday_only",
        "model_group_suffix": "_vel_midday",
        "reuse_stage1_from": "all_day",
        "overrides": {
          "outputs": { "run_name": "vel_midday" },
          "training": {
            "stage2_session_filter": {
              "enabled": true,
              "include_buckets": ["MIDDAY"]
            }
          }
        }
      },
      {
        "run_id": "midday_late",
        "model_group_suffix": "_vel_midday_late",
        "reuse_stage1_from": "all_day",
        "overrides": {
          "outputs": { "run_name": "vel_midday_late" },
          "training": {
            "stage2_session_filter": {
              "enabled": true,
              "include_buckets": ["MIDDAY", "LATE_SESSION"]
            }
          }
        }
      }
    ]
  }
}
