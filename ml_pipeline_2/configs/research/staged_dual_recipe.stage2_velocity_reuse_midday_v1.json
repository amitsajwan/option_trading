{
  "schema_version": 1,
  "experiment_kind": "staged_dual_recipe_v1",
  "inputs": {
    "parquet_root": "../../../.data/ml_pipeline/parquet_data",
    "support_dataset": "snapshots_ml_flat_v2"
  },
  "outputs": {
    "artifacts_root": "../../artifacts/research",
    "run_name": "staged_dual_recipe_stage2_velocity_reuse_midday_v1"
  },
  "catalog": {
    "models_by_stage": {
      "stage1": [
        "xgb_shallow",
        "xgb_balanced",
        "lgbm_fast",
        "lgbm_dart",
        "logreg_balanced"
      ],
      "stage2": [
        "xgb_shallow",
        "xgb_balanced",
        "lgbm_fast",
        "logreg_balanced"
      ],
      "stage3": [
        "xgb_shallow",
        "xgb_balanced",
        "lgbm_dart",
        "logreg_balanced"
      ]
    },
    "feature_sets_by_stage": {
      "stage1": [
        "fo_velocity_v1",
        "fo_expiry_aware_v3",
        "fo_full",
        "fo_oi_pcr_momentum"
      ],
      "stage2": [
        "fo_velocity_v1"
      ],
      "stage3": [
        "fo_velocity_v1",
        "fo_expiry_aware_v3",
        "fo_full",
        "fo_no_time_context"
      ]
    },
    "recipe_catalog_id": "midday_l3_adjacent_v1"
  },
  "windows": {
    "research_train": {
      "start": "2020-08-03",
      "end": "2024-04-30"
    },
    "research_valid": {
      "start": "2024-05-01",
      "end": "2024-07-31"
    },
    "full_model": {
      "start": "2020-08-03",
      "end": "2024-07-31"
    },
    "final_holdout": {
      "start": "2024-08-01",
      "end": "2024-10-31"
    }
  },
  "views": {
    "stage1_view_id": "stage1_entry_view_v2",
    "stage2_view_id": "stage2_direction_view_v3_candidate",
    "stage3_view_id": "stage3_recipe_view_v3_candidate"
  },
  "labels": {
    "stage1_labeler_id": "entry_best_recipe_v1",
    "stage2_labeler_id": "direction_best_recipe_v1",
    "stage3_labeler_id": "recipe_best_positive_v1"
  },
  "training": {
    "stage1_trainer_id": "binary_catalog_v1",
    "stage2_trainer_id": "binary_catalog_v1",
    "stage3_trainer_id": "ovr_recipe_catalog_v1",
    "preprocess": {
      "max_missing_rate": 0.35,
      "clip_lower_q": 0.01,
      "clip_upper_q": 0.99
    },
    "cv_config": {
      "train_days": 84,
      "valid_days": 21,
      "test_days": 21,
      "step_days": 21,
      "purge_days": 0,
      "embargo_days": 0,
      "purge_mode": "days",
      "embargo_rows": 0,
      "event_end_col": null
    },
    "objectives_by_stage": {
      "stage1": "brier",
      "stage2": "brier",
      "stage3": "brier"
    },
    "random_state": 42,
    "runtime": {
      "model_n_jobs": 4
    },
    "search_options_by_stage": {
      "stage1": {
        "hpo": {
          "enabled": true,
          "strategy": "random",
          "trials_per_model": 3,
          "sampler_seed": 42
        }
      },
      "stage2": {
        "hpo": {
          "enabled": true,
          "strategy": "random",
          "trials_per_model": 3,
          "sampler_seed": 42
        }
      },
      "stage3": {
        "hpo": {
          "enabled": true,
          "strategy": "random",
          "trials_per_model": 3,
          "sampler_seed": 42
        }
      }
    },
    "stage2_session_filter": {
      "enabled": true,
      "include_buckets": [
        "MIDDAY"
      ]
    },
    "cost_per_trade": 0.0006
  },
  "policy": {
    "stage1_policy_id": "entry_threshold_v1",
    "stage2_policy_id": "direction_gate_economic_balance_v1",
    "stage3_policy_id": "recipe_economic_balance_v1",
    "stage1": {
      "threshold_grid": [
        0.45,
        0.5,
        0.55,
        0.6
      ]
    },
    "stage2": {
      "trade_threshold_grid": [
        0.45,
        0.5,
        0.55,
        0.6
      ],
      "ce_threshold_grid": [
        0.55,
        0.6,
        0.65
      ],
      "pe_threshold_grid": [
        0.55,
        0.6,
        0.65
      ],
      "min_edge_grid": [
        0.05,
        0.1,
        0.15
      ]
    },
    "stage3": {
      "threshold_grid": [
        0.45,
        0.5,
        0.55,
        0.6
      ],
      "margin_grid": [
        0.02,
        0.05,
        0.1
      ],
      "validation_min_trades_soft": 250,
      "side_share_min": 0.3,
      "side_share_max": 0.7,
      "prefer_non_negative_returns": true,
      "prefer_profit_factor_min": 1.0,
      "non_inferior_drawdown_slack": 0.01
    }
  },
  "runtime": {
    "block_expiry": false,
    "prefilter_gate_ids": [
      "rollout_guard_v1",
      "risk_halt_pause_v1",
      "valid_entry_phase_v1",
      "startup_warmup_v1",
      "feature_freshness_v1",
      "feature_completeness_v1",
      "liquidity_gate_v1",
      "regime_gate_v1",
      "regime_confidence_gate_v1"
    ]
  },
  "publish": {
    "publisher_id": "staged_bundle_v1"
  },
  "hard_gates": {
    "stage1": {
      "roc_auc_min": 0.55,
      "brier_max": 0.22,
      "roc_auc_drift_half_split_max_abs": 0.05
    },
    "stage2": {
      "roc_auc_min": 0.55,
      "brier_max": 0.22
    },
    "stage3": {
      "max_drawdown_slack": 0.01
    },
    "combined": {
      "profit_factor_min": 1.5,
      "max_drawdown_pct_max": 0.1,
      "trades_min": 50,
      "net_return_sum_min": 0.0,
      "side_share_min": 0.3,
      "side_share_max": 0.7,
      "block_rate_min": 0.25
    }
  }
}
