{
  "inputs": {
    "base_manifest": "fo_expiry_aware_recovery.fast_path_4y.json"
  },
  "matrix": {
    "recipe_fanout": true,
    "recipes": [
      {
        "recipe_id": "ATR_H15_TP30_SL8",
        "horizon_minutes": 15,
        "take_profit_pct": 0.003,
        "stop_loss_pct": 0.0008,
        "barrier_mode": "atr_scaled"
      },
      {
        "recipe_id": "FIXED_H15_TP30_SL8",
        "horizon_minutes": 15,
        "take_profit_pct": 0.003,
        "stop_loss_pct": 0.0008,
        "barrier_mode": "fixed"
      }
    ],
    "models": [
      "xgb_regularized"
    ],
    "feature_sets": [
      "fo_expiry_aware_v2"
    ],
    "variants": [
      {
        "variant_id": "baseline",
        "description": "Fast-path control lane."
      },
      {
        "variant_id": "allow_atr_high",
        "description": "Keep atr-high rows; isolate the ATR regime filter.",
        "scenario_overrides": {
          "candidate_filter": {
            "exclude_regime_atr_high": false
          }
        }
      },
      {
        "variant_id": "allow_expiry_day",
        "description": "Keep expiry-day rows; isolate the expiry-day filter.",
        "scenario_overrides": {
          "candidate_filter": {
            "exclude_expiry_day": false
          }
        }
      },
      {
        "variant_id": "allow_atr_high_and_expiry_day",
        "description": "Expand the opportunity set under the same cusum event sampling.",
        "scenario_overrides": {
          "candidate_filter": {
            "exclude_expiry_day": false,
            "exclude_regime_atr_high": false
          }
        }
      },
      {
        "variant_id": "no_cusum_allow_atr_high_and_expiry_day",
        "description": "Disable cusum after both filters are relaxed.",
        "scenario_overrides": {
          "event_sampling_mode": "none",
          "candidate_filter": {
            "require_event_sampled": false,
            "exclude_expiry_day": false,
            "exclude_regime_atr_high": false
          }
        }
      }
    ]
  },
  "outputs": {
    "matrix_root": "../../artifacts/research_matrices",
    "matrix_name": "recovery_ablation_opportunity_4y"
  },
  "launch": {
    "background": true,
    "max_parallel": 10,
    "poll_seconds": 120,
    "job_root": "../../artifacts/background_jobs"
  }
}
