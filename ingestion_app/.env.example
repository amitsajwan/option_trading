# ingestion_app runtime defaults

REDIS_HOST=localhost
REDIS_PORT=6380
REDIS_DB=0

API_PORT=8004
INSTRUMENT_SYMBOL=BANKNIFTY26MARFUT

# Set 1 to run mock provider path
USE_MOCK_KITE=0

# Optional: direct credentials from env
KITE_API_KEY=
KITE_ACCESS_TOKEN=

# Optional: credential file override
KITE_CREDENTIALS_PATH=

# Session gate (IST)
MARKET_SESSION_ENABLED=1
MARKET_TIMEZONE=Asia/Kolkata
MARKET_OPEN_TIME=09:15
MARKET_CLOSE_TIME=15:30
NSE_HOLIDAYS_FILE=./config/nse_holidays.json
IDLE_SLEEP_SECONDS=60

# Topics
LIVE_TOPIC=market:snapshot:v1
HISTORICAL_TOPIC=market:snapshot:v1:historical
SNAPSHOT_V1_TOPIC=market:snapshot:v1
