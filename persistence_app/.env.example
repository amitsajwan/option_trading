# persistence_app runtime defaults

REDIS_HOST=localhost
REDIS_PORT=6380
REDIS_DB=0
SNAPSHOT_V1_TOPIC=market:snapshot:v1

MONGO_HOST=localhost
MONGO_PORT=27017
MONGO_DB=trading_ai
MONGO_URI=
MONGODB_URI=

MONGO_COLL_SNAPSHOTS=phase1_market_snapshots
MONGO_PERSIST_TTL_DAYS=0

# Session gate (health behavior)
MARKET_SESSION_ENABLED=1
MARKET_TIMEZONE=Asia/Kolkata
MARKET_OPEN_TIME=09:15
MARKET_CLOSE_TIME=15:30
NSE_HOLIDAYS_FILE=./config/nse_holidays.json

# Topic split
LIVE_TOPIC=market:snapshot:v1
HISTORICAL_TOPIC=market:snapshot:v1:historical
